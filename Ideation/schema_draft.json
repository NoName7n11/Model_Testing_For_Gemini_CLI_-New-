{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Gemini CLI Evaluation Benchmark Dataset Schema",
  "type": "object",
  "properties": {
    "task_id": {
      "type": "string"
    },
    "repository": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "owner": { "type": "string" },
        "language_primary": { "type": "string" },
        "commit_hash_base": { 
          "type": "string" 
        }
      },
      "required": ["name", "owner", "language_primary", "commit_hash_base"]
    },
    "problem_statement": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { 
          "type": "string"
        },
        "target_files": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["title", "description"]
    },
    "evaluation_criteria": {
      "type": "object",
      "properties": {
        "gold_patch": {
          "type": "string"
        },
        "test_patch": {
          "type": "string"
        },
        "success_command": {
          "type": "string"
        },
        "complexity_flags": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["gold_patch", "test_patch", "success_command"]
    }
  },
  "required": ["task_id", "repository", "problem_statement", "evaluation_criteria"]
}
